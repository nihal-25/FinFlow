PORT=3002
NODE_ENV=production

DATABASE_URL=postgresql://user:password@host:5432/finflow
REDIS_URL=redis://:password@host:6379

KAFKA_BROKERS=your-upstash-broker.upstash.io:9092
KAFKA_CLIENT_ID=transaction-service
# Upstash Kafka requires SASL — set these too:
KAFKA_SASL_USERNAME=your-upstash-username
KAFKA_SASL_PASSWORD=your-upstash-password

JWT_ACCESS_SECRET=change-me-same-as-api-gateway

CORS_ORIGIN=https://your-app.vercel.app
LOG_LEVEL=info
