PORT=3001
NODE_ENV=production

DATABASE_URL=postgresql://user:password@host:5432/finflow
REDIS_URL=redis://:password@host:6379

JWT_ACCESS_SECRET=change-me-min-32-chars-random-string-here
JWT_REFRESH_SECRET=change-me-min-32-chars-different-random-string

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

CORS_ORIGIN=https://your-app.vercel.app

# Internal Railway URLs (use private networking)
TRANSACTION_SERVICE_URL=http://transaction-service.railway.internal:3002
ANALYTICS_SERVICE_URL=http://analytics-service.railway.internal:3005

LOG_LEVEL=info
